#!/bin/sh
# EGOS CRCDM Post-Commit Hook
# Detects committed changes, updates DAG with commit hash
# Part of Cross-Repo Change Detection Mesh (CRCDM)

set -eu

CRCDM_ROOT="${HOME}/.egos/crcdm"
HOOK_NAME="post-commit"
REPO_PATH="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
REPO_NAME="$(basename "$REPO_PATH")"

echo "🔍 CRCDM [$HOOK_NAME] — Recording commit in $REPO_NAME..."

# Get commit info
COMMIT_HASH="$(git rev-parse HEAD 2>/dev/null || echo 'unknown')"
COMMIT_SHORT="${COMMIT_HASH:0:8}"
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo 'unknown')"
AUTHOR="$(git log -1 --format='%an' HEAD 2>/dev/null || echo 'unknown')"
MESSAGE="$(git log -1 --format='%s' HEAD 2>/dev/null || echo '')"
TIMESTAMP="$(date -u +%s)"

# Get files changed in this commit
FILES_CHANGED="$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)"
FILES_COUNT="$(echo "$FILES_CHANGED" | grep -c . 2>/dev/null || echo '0')"

# Calculate impact
IMPACT="low"
for file in $FILES_CHANGED; do
  case "$file" in
    *runtime*|*auth*|*security*|*middleware*|*.env*)
      IMPACT="critical"
      break
      ;;
    *api/*|*db/*|*config/*|*migrations/*)
      if [ "$IMPACT" != "critical" ]; then
        IMPACT="high"
      fi
      ;;
    *components/*|*features/*|*hooks/*)
      if [ "$IMPACT" = "low" ]; then
        IMPACT="medium"
      fi
      ;;
  esac
done

# Generate node ID
CHANGE_HASH="$(echo "${REPO_PATH}:${COMMIT_HASH}:$(date +%s)" | sha256sum | cut -d' ' -f1)"
NODE_ID="${CHANGE_HASH:0:16}"

# Log to CRCDM
{
  echo "${TIMESTAMP} ${NODE_ID} ${REPO_NAME} ${BRANCH} ${IMPACT} COMMIT:${COMMIT_SHORT}: ${MESSAGE}"
} >> "${CRCDM_ROOT}/logs/${HOOK_NAME}.log"

# Update DAG with commit info
if command -v jq >/dev/null 2>&1; then
  DAG_FILE="${CRCDM_ROOT}/dag/dag.json"
  if [ -f "$DAG_FILE" ]; then
    # Try to find and update pre-commit node, or create new
    NODE=$(jq -n \
      --arg id "$NODE_ID" \
      --arg repo "$REPO_NAME" \
      --arg branch "$BRANCH" \
      --arg impact "$IMPACT" \
      --arg commit "$COMMIT_HASH" \
      --arg author "$AUTHOR" \
      --arg message "$MESSAGE" \
      --argjson files_count "$FILES_COUNT" \
      --arg timestamp "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
      '{id: $id, repo: $repo, branch: $branch, impact: $impact, commit: $commit, author: $author, message: $message, files_count: $files_count, timestamp: $timestamp, type: "commit", status: "committed"}')
    
    jq --argjson node "$NODE" '.nodes += [$node]' "$DAG_FILE" > "${DAG_FILE}.tmp" && mv "${DAG_FILE}.tmp" "$DAG_FILE"
  fi
fi

# Impact emoji
IMPACT_EMOJI="⚪"
case "$IMPACT" in
  critical) IMPACT_EMOJI="🔴" ;;
  high) IMPACT_EMOJI="🟠" ;;
  medium) IMPACT_EMOJI="🟡" ;;
esac

echo "  ✅ Recorded: ${NODE_ID}"
echo "  🔗 Commit: ${COMMIT_SHORT}"
echo "  📊 Impact: ${IMPACT_EMOJI} ${IMPACT}"
echo "  👤 Author: ${AUTHOR}"
echo "  📝 Files: ${FILES_COUNT}"

# Check for cross-repo impact
if echo "$FILES_CHANGED" | grep -qE "(packages/shared|.guarani|.windsurf)"; then
  echo "  🌐 Cross-repo impact detected!"
  echo "     Run: source ~/.egos_aliases && egos-sync-deps"
fi

# Trigger notification to other repos if critical impact
if [ "$IMPACT" = "critical" ]; then
  NOTIFICATION="${CRCDM_ROOT}/notifications/critical-$(date +%s).json"
  cat > "$NOTIFICATION" <<EOF
{
  "type": "critical_commit",
  "source": "$REPO_NAME",
  "commit": "$COMMIT_HASH",
  "timestamp": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "message": "$MESSAGE",
  "node_id": "$NODE_ID"
}
EOF
  echo "  🚨 Critical notification created"
fi

# Update state
STATE_FILE="${CRCDM_ROOT}/state/last-commit.json"
cat > "$STATE_FILE" <<EOF
{
  "repo": "$REPO_NAME",
  "commit": "$COMMIT_HASH",
  "branch": "$BRANCH",
  "timestamp": "$(date -u +"%Y-%m-%dT%H:%M:%SZ")",
  "impact": "$IMPACT",
  "node_id": "$NODE_ID"
}
EOF

echo "✅ CRCDM [$HOOK_NAME] — Complete"
