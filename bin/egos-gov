#!/bin/bash
# ═══════════════════════════════════════════════════════════
# 🔱 EGOS Governance Mesh v1.0
# Self-healing governance sync for multi-repo AI workspaces
# 
# Usage:
#   egos-gov check   — Validate governance (exit 0=ok, 1=broken)
#   egos-gov sync    — Create/fix symlinks, hooks, workflows
#   egos-gov status  — Show all repos at a glance
#   egos-gov init    — Onboard current directory as EGOS repo
# ═══════════════════════════════════════════════════════════
set -euo pipefail

EGOS_HOME="${EGOS_HOME:-$HOME/.egos}"
MANIFEST="$EGOS_HOME/manifest.json"
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

# ── Helpers ──
die()  { echo -e "${RED}❌ $*${NC}" >&2; exit 1; }
ok()   { echo -e "${GREEN}✅${NC} $*"; }
warn() { echo -e "${YELLOW}⚠️${NC}  $*"; }
info() { echo -e "${CYAN}ℹ️${NC}  $*"; }

json_array() {
  python3 -c "import json,sys; d=json.load(open('$MANIFEST')); [print(x) for x in d.get('$1',[])]" 2>/dev/null
}

json_repos() {
  python3 -c "
import json,sys
d=json.load(open('$MANIFEST'))
for name,cfg in d.get('repos',{}).items():
  print(f\"{name}|{cfg['path']}|{cfg['mode']}|{cfg.get('hooks',True)}\")
" 2>/dev/null
}

# ── Detect repo root ──
find_repo_root() {
  local cur="${1:-$PWD}"
  while [ "$cur" != "/" ]; do
    [ -e "$cur/.git" ] && echo "$cur" && return 0
    cur="$(dirname "$cur")"
  done
  return 1
}

# ══════════════════════════════════════════════════════════
# CHECK — Validate governance for current repo
# ══════════════════════════════════════════════════════════
cmd_check() {
  local quiet="${1:-}"
  local root
  root=$(find_repo_root) || die "Not inside a git repo"
  local repo_name=$(basename "$root")
  local errors=0

  [ "$quiet" != "--quiet" ] && echo -e "\n${BLUE}🔍 Governance check: $repo_name${NC}"

  # 1. Check .egos symlink
  if [ -L "$root/.egos" ] && [ -d "$root/.egos" ]; then
    [ "$quiet" != "--quiet" ] && ok ".egos symlink"
  else
    [ "$quiet" != "--quiet" ] && warn ".egos symlink missing/broken"
    errors=$((errors+1))
  fi

  # 2. Check required local files
  for f in $(json_array required_local_files); do
    if [ -f "$root/$f" ]; then
      [ "$quiet" != "--quiet" ] && ok "$f"
    else
      [ "$quiet" != "--quiet" ] && warn "$f MISSING"
      errors=$((errors+1))
    fi
  done

  # 3. Check shared .guarani symlinks
  local shared_ok=0 shared_total=0
  for f in $(json_array shared_guarani); do
    shared_total=$((shared_total+1))
    local target="$root/.guarani/$f"
    if [ -L "$target" ] && [ -f "$target" ]; then
      shared_ok=$((shared_ok+1))
    elif [ -f "$target" ]; then
      # Local copy exists but not symlink — drift
      [ "$quiet" != "--quiet" ] && warn ".guarani/$f is a local copy (should be symlink)"
      errors=$((errors+1))
    else
      [ "$quiet" != "--quiet" ] && warn ".guarani/$f MISSING"
      errors=$((errors+1))
    fi
  done
  [ "$quiet" != "--quiet" ] && ok "Shared .guarani: $shared_ok/$shared_total symlinked"

  # 4. Check AI tools
  if command -v codex >/dev/null 2>&1; then
    [ "$quiet" != "--quiet" ] && ok "Codex CLI available"
  else
    [ "$quiet" != "--quiet" ] && info "Codex CLI not installed (optional)"
  fi

  if [ -f "$root/.env" ]; then
    if grep -q 'EGOS_ORCHESTRATOR_PROVIDER' "$root/.env" 2>/dev/null; then
      [ "$quiet" != "--quiet" ] && ok "Alibaba/Qwen configured"
    else
      [ "$quiet" != "--quiet" ] && info "EGOS_ORCHESTRATOR_PROVIDER not in .env"
    fi
  fi

  # 5. Check pre-commit hook
  if [ -f "$root/.husky/pre-commit" ] || [ -f "$root/.git/hooks/pre-commit" ]; then
    if grep -q 'egos-gov' "$root/.husky/pre-commit" 2>/dev/null || \
       grep -q 'egos-gov' "$root/.git/hooks/pre-commit" 2>/dev/null; then
      [ "$quiet" != "--quiet" ] && ok "Pre-commit governance hook"
    else
      [ "$quiet" != "--quiet" ] && info "Pre-commit exists but no egos-gov check"
    fi
  else
    [ "$quiet" != "--quiet" ] && info "No pre-commit hook"
  fi

  if [ $errors -eq 0 ]; then
    [ "$quiet" != "--quiet" ] && echo -e "\n${GREEN}✅ Governance OK ($repo_name)${NC}"
    return 0
  else
    [ "$quiet" != "--quiet" ] && echo -e "\n${RED}❌ $errors governance issues ($repo_name) — run: egos-gov sync${NC}"
    return 1
  fi
}

# ══════════════════════════════════════════════════════════
# SYNC — Fix all governance for current repo (or all repos)
# ══════════════════════════════════════════════════════════
cmd_sync() {
  local target="${1:-}"
  
  if [ "$target" = "--all" ]; then
    echo -e "\n${BLUE}🔄 EGOS Governance Mesh — Full Sync${NC}"
    echo "═══════════════════════════════════════════════════════════"
    
    while IFS='|' read -r name path mode hooks; do
      [ "$mode" = "mapped-only" ] && { info "$name — mapped-only, skipping"; continue; }
      [ ! -d "$path" ] && { warn "$name — $path not found, skipping"; continue; }
      echo -e "\n${CYAN}📂 $name${NC}"
      sync_repo "$path"
    done < <(json_repos)
    
    echo -e "\n${GREEN}✅ Full sync complete!${NC}"
    return 0
  fi

  local root
  root=$(find_repo_root) || die "Not inside a git repo"
  echo -e "\n${BLUE}🔄 Syncing: $(basename "$root")${NC}"
  sync_repo "$root"
  echo -e "\n${GREEN}✅ Sync complete!${NC}"
}

sync_repo() {
  local root="$1"
  
  # A. .egos symlink
  if [ -L "$root/.egos" ]; then
    local target=$(readlink -f "$root/.egos" 2>/dev/null || readlink "$root/.egos")
    if [ "$target" = "$EGOS_HOME" ] || [ "$target" = "$(readlink -f $EGOS_HOME)" ]; then
      ok ".egos symlink"
    else
      rm "$root/.egos"; ln -sf "$EGOS_HOME" "$root/.egos"
      ok ".egos symlink fixed"
    fi
  elif [ ! -e "$root/.egos" ]; then
    ln -sf "$EGOS_HOME" "$root/.egos"
    ok ".egos symlink created"
  fi

  # B. Shared .guarani files — symlink from ~/.egos/guarani/
  for f in $(json_array shared_guarani); do
    local target="$root/.guarani/$f"
    local source="$EGOS_HOME/guarani/$f"
    mkdir -p "$(dirname "$target")"
    
    if [ -L "$target" ]; then
      ok ".guarani/$f"
    elif [ -f "$target" ]; then
      # Local copy exists — check if identical to shared
      if [ -f "$source" ] && cmp -s "$target" "$source" 2>/dev/null; then
        rm "$target"; ln -sf "$source" "$target"
        ok ".guarani/$f → symlink (was identical copy)"
      else
        warn ".guarani/$f — LOCAL OVERRIDE (keeping)"
      fi
    else
      [ -f "$source" ] && ln -sf "$source" "$target" && ok ".guarani/$f → symlink"
    fi
  done

  # C. Workflow symlinks — for both .agent/ and .windsurf/
  for agent_dir in .agent .windsurf; do
    mkdir -p "$root/$agent_dir/workflows"
    for wf in $(json_array shared_workflows); do
      local target="$root/$agent_dir/workflows/$wf"
      local source="$EGOS_HOME/workflows/$wf"
      if [ -L "$target" ]; then
        : # already a symlink
      elif [ -f "$target" ]; then
        warn "$agent_dir/workflows/$wf — LOCAL OVERRIDE (keeping)"
      elif [ -f "$source" ]; then
        ln -sf "$source" "$target"
      fi
    done
  done
  ok "Workflows synced (.agent + .windsurf)"

  # D. Skills symlinks
  for agent_dir in .agent .windsurf; do
    mkdir -p "$root/$agent_dir/skills"
    for skill in $(json_array shared_skills); do
      local target="$root/$agent_dir/skills/$skill"
      local source="$EGOS_HOME/skills/$skill"
      if [ -L "$target" ]; then
        : # already a symlink
      elif [ -e "$target" ]; then
        warn "$agent_dir/skills/$skill — LOCAL OVERRIDE (keeping)"
      elif [ -d "$source" ]; then
        ln -sf "$source" "$target"
      fi
    done
  done
  ok "Skills synced"

  # E. .gitignore — ensure .egos is ignored
  if [ -f "$root/.gitignore" ]; then
    grep -q '^\.egos$' "$root/.gitignore" 2>/dev/null || echo ".egos" >> "$root/.gitignore"
  fi

  # F. Install pre-commit hook (non-destructive)
  install_hook "$root"
}

install_hook() {
  local root="$1"
  local hook_line='[ -x "$HOME/.egos/bin/egos-gov" ] && "$HOME/.egos/bin/egos-gov" check --quiet || { echo "⚠️  Governance drift detected. Run: egos-gov sync"; }'
  
  # If husky exists, append to existing pre-commit
  if [ -d "$root/.husky" ]; then
    if [ -f "$root/.husky/pre-commit" ]; then
      if ! grep -q 'egos-gov' "$root/.husky/pre-commit" 2>/dev/null; then
        echo "" >> "$root/.husky/pre-commit"
        echo "# EGOS Governance Check" >> "$root/.husky/pre-commit"
        echo "$hook_line" >> "$root/.husky/pre-commit"
        ok "Added egos-gov to .husky/pre-commit"
      fi
    else
      echo '#!/bin/sh' > "$root/.husky/pre-commit"
      echo "" >> "$root/.husky/pre-commit"
      echo "# EGOS Governance Check" >> "$root/.husky/pre-commit"
      echo "$hook_line" >> "$root/.husky/pre-commit"
      chmod +x "$root/.husky/pre-commit"
      ok "Created .husky/pre-commit with egos-gov"
    fi
  else
    # Fallback: .git/hooks/pre-commit
    local hook="$root/.git/hooks/pre-commit"
    if [ ! -f "$hook" ]; then
      echo '#!/bin/sh' > "$hook"
      echo "" >> "$hook"
      echo "# EGOS Governance Check" >> "$hook"
      echo "$hook_line" >> "$hook"
      chmod +x "$hook"
      ok "Created .git/hooks/pre-commit"
    elif ! grep -q 'egos-gov' "$hook" 2>/dev/null; then
      echo "" >> "$hook"
      echo "# EGOS Governance Check" >> "$hook"
      echo "$hook_line" >> "$hook"
      ok "Added egos-gov to .git/hooks/pre-commit"
    fi
  fi
}

# ══════════════════════════════════════════════════════════
# STATUS — Show all repos governance at a glance
# ══════════════════════════════════════════════════════════
cmd_status() {
  echo -e "\n${BLUE}🔱 EGOS Governance Mesh — Status${NC}"
  echo "═══════════════════════════════════════════════════════════"
  printf "%-18s %-8s %-6s %-8s %-6s\n" "REPO" "SYMLINK" "GUARD" "HOOKS" "MODE"
  echo "───────────────────────────────────────────────────────────"
  
  while IFS='|' read -r name path mode hooks; do
    if [ ! -d "$path" ]; then
      printf "%-18s ${RED}%-8s${NC}\n" "$name" "NOT FOUND"
      continue
    fi
    
    # Symlink check
    local sym="❌"
    [ -L "$path/.egos" ] && [ -d "$path/.egos" ] && sym="✅"
    
    # Guarani check
    local guard="❌"
    local shared_ok=0 shared_total=0
    for f in $(json_array shared_guarani); do
      shared_total=$((shared_total+1))
      [ -L "$path/.guarani/$f" ] && [ -f "$path/.guarani/$f" ] && shared_ok=$((shared_ok+1))
    done
    [ "$shared_ok" = "$shared_total" ] && guard="✅" || guard="${shared_ok}/${shared_total}"
    
    # Hooks check
    local hk="—"
    if [ "$hooks" = "true" ] || [ "$hooks" = "True" ]; then
      if grep -rq 'egos-gov' "$path/.husky/pre-commit" "$path/.git/hooks/pre-commit" 2>/dev/null; then
        hk="✅"
      else
        hk="❌"
      fi
    else
      hk="skip"
    fi
    
    printf "%-18s %-8s %-6s %-8s %-6s\n" "$name" "$sym" "$guard" "$hk" "$mode"
  done < <(json_repos)
  
  echo ""
  
  # AI tools status
  echo -e "${CYAN}🤖 AI Tools:${NC}"
  if command -v codex >/dev/null 2>&1; then
    ok "Codex CLI: $(codex --version 2>/dev/null || echo 'installed')"
  else
    info "Codex CLI: not in PATH"
  fi
  
  # Check Alibaba from egos-lab .env
  if [ -f "/home/enio/egos-lab/.env" ]; then
    local provider=$(grep 'EGOS_ORCHESTRATOR_PROVIDER' /home/enio/egos-lab/.env 2>/dev/null | cut -d= -f2 | head -1)
    local model=$(grep 'EGOS_ORCHESTRATOR_MODEL' /home/enio/egos-lab/.env 2>/dev/null | cut -d= -f2 | head -1)
    [ -n "$provider" ] && ok "Alibaba: provider=$provider model=$model" || info "Alibaba: not configured"
  fi
  
  echo ""
}

# ══════════════════════════════════════════════════════════
# INIT — Onboard a new repo
# ══════════════════════════════════════════════════════════
cmd_init() {
  local root
  root=$(find_repo_root) || die "Not inside a git repo"
  local name=$(basename "$root")
  
  echo -e "\n${BLUE}🔱 Initializing EGOS governance for: $name${NC}"
  
  # Create required files if missing
  for f in $(json_array required_local_files); do
    if [ ! -f "$root/$f" ]; then
      case "$f" in
        AGENTS.md) echo "# Agents — $name" > "$root/$f"; ok "Created $f" ;;
        TASKS.md)  echo "# Tasks — $name" > "$root/$f"; ok "Created $f" ;;
        .windsurfrules) echo "# Windsurf Rules — $name" > "$root/$f"; ok "Created $f" ;;
        *) touch "$root/$f"; ok "Created $f (empty)" ;;
      esac
    fi
  done
  
  # Run full sync
  sync_repo "$root"
  
  echo -e "\n${GREEN}✅ $name is now an EGOS-governed repo!${NC}"
  echo "Add it to ~/.egos/manifest.json repos section."
}

# ══════════════════════════════════════════════════════════
# Main dispatch
# ══════════════════════════════════════════════════════════
case "${1:-help}" in
  check)  cmd_check "${2:-}" ;;
  sync)   cmd_sync "${2:-}" ;;
  status) cmd_status ;;
  init)   cmd_init ;;
  *)
    echo "🔱 EGOS Governance Mesh v1.0"
    echo ""
    echo "Usage: egos-gov <command>"
    echo ""
    echo "Commands:"
    echo "  check [--quiet]  Validate governance (exit 0/1)"
    echo "  sync [--all]     Fix governance for current or all repos"
    echo "  status           Show all repos at a glance"
    echo "  init             Onboard current repo"
    ;;
esac
